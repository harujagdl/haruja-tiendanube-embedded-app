{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "app",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors 'self' https://*.tiendanube.com https://*.mitiendanube.com https://*.nuvemshop.com.br https://*.lojavirtualenv.com.br;"
          },
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/dashboard/**",
        "function": "api"
      },
      {
        "source": "/apartados-historial/**",
        "destination": "/apartados-historial/index.html"
      },
      {
        "source": "/apartados/**",
        "destination": "/apartados/index.html"
      },
      {
        "source": "/lealtad/**",
        "destination": "/lealtad/index.html"
      },
      {
        "source": "/auth/tiendanube/**",
        "function": "tiendanubeAuth"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
