{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "app",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "ALLOWALL"
          },
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors 'self' https://*.mitiendanube.com https://mitiendanube.com https://*.tiendanube.com https://tiendanube.com https://partners.tiendanube.com;"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/apartados-historial",
        "destination": "/apartados-historial/index.html"
      },
      {
        "source": "/apartados-historial/**",
        "destination": "/apartados-historial/index.html"
      },
      {
        "source": "/apartados",
        "destination": "/apartados/index.html"
      },
      {
        "source": "/apartados/**",
        "destination": "/apartados/index.html"
      },
      {
        "source": "/lealtad",
        "destination": "/lealtad/index.html"
      },
      {
        "source": "/lealtad/**",
        "destination": "/lealtad/index.html"
      },
      {
        "source": "/dashboard/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
