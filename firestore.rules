rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        (
          request.auth.token.email == "yair.tenorio.silva@gmail.com" ||
          request.auth.token.email == "harujagdl@gmail.com" ||
          request.auth.token.email == "harujagdl.ventas@gmail.com"
        );
    }

    function isAdmin() {
      return isAdminEmail();
    }


    function hasOnlyFields(data, allowedFields) {
      return data.keys().hasOnly(allowedFields);
    }

    function isValidPrendaPublica() {
      return hasOnlyFields(request.resource.data, [
        "codigo",
        "code",
        "codigoBase",
        "baseCode",
        "providerCode",
        "typeCode",
        "colorCode",
        "tallaCode",
        "providerName",
        "typeName",
        "colorName",
        "tallaName",
        "descripcion",
        "detalles",
        "creadoPor",
        "orden",
        "seqNumber",
        "createdAt",
        "updatedAt"
      ]) &&
      (
        !("orden" in request.resource.data) ||
        request.resource.data.orden is number
      ) &&
      (
        !("seqNumber" in request.resource.data) ||
        request.resource.data.seqNumber is number
      );
    }

    // Diccionario (colección fallback)
    match /diccionario/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // Diccionario por categoría (colecciones actuales)
    match /diccionario_tipos/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /diccionario_proveedores/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /diccionario_colores/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /diccionario_tallas/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // Prendas públicas
    match /prendas/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /HarujaPrendas_2025_public/{doc=**} {
      allow read: if true;
      allow update: if isAdmin() && isValidPrendaPublica();
      allow create: if isAdmin() && isValidPrendaPublica();
      allow delete: if isAdmin();
    }

    match /HarujaPrendas_2025/{docId} {
      allow read, write: if isAdminEmail();
    }

    // Datos sensibles de admin
    match /HarujaPrendas_2025_admin/{doc} {
      allow read, write: if isAdminEmail();
    }

    match /counters/{doc} {
      allow read, write: if request.auth != null;
    }

    match /modelos/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /modelos/{doc}/variantes/{variantDoc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /modelos_index/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /metadata/{doc} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // Resúmenes de ventas usados en Meta vs venta (sin exponer ventas crudas)
    match /sales_totals/{doc=**} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /ventas_totales_mensuales/{doc=**} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /goals_sales/{doc=**} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // Cualquier otra colección cerrada por default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
